# Copy this file to `.env` (which is gitignored) and fill in your token.
# NEVER commit .env or paste your token into chat. config.py auto-loads .env.

# --- Intrinio (delisted-inclusive prices; keep EDGAR for fundamentals) ---
STOCKSCAN_PRICE_PROVIDER=intrinio
STOCKSCAN_INTRINIO_KEY=your_intrinio_api_key_here

# --- or Tiingo ---
# STOCKSCAN_PRICE_PROVIDER=tiingo
# STOCKSCAN_TIINGO_TOKEN=your_tiingo_api_token_here

# --- Local LLM for the NARRATE stage (optional) ---
# STOCKSCAN_LLM_URL=http://localhost:11434/v1
# STOCKSCAN_LLM_MODEL=qwen2.5:32b
